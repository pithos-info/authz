<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Immutable. No deleted, utcModifiedAt, or updatedBy columns. -->
    <changeSet id="V001__create_app" author="pithos">
        <createTable tableName="App">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="slug" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="ownerId" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="parentAppId" type="VARCHAR(36)">
                <constraints nullable="true"/>
            </column>
            <column name="utcCreatedAt" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="createdBy" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
