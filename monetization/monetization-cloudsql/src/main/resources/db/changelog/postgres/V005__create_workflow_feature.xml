<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Association — hard delete, no soft-delete, no update fields.          -->
    <!-- Composite primary key: (workflowId, featureId).                       -->
    <!-- stepOrder defines execution sequence within the workflow.              -->
    <changeSet id="V005__create_workflow_feature" author="pithos">
        <createTable tableName="WorkflowFeature">
            <column name="appId" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="workflowId" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="featureId" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="stepOrder" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="utcCreatedAt" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="createdBy" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey
            tableName="WorkflowFeature"
            columnNames="workflowId, featureId"
            constraintName="pk_workflow_feature"/>
    </changeSet>

</databaseChangeLog>
