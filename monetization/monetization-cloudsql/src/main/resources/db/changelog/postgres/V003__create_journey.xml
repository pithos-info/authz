<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Immutable. No deleted, utcModifiedAt, or updatedBy columns.            -->
    <!-- goal and outcomeStatement are TEXT — user-authored content, unbounded.  -->
    <changeSet id="V003__create_journey" author="pithos">
        <createTable tableName="Journey">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="appId" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="displayName" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="goal" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="outcomeStatement" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="version" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="parentJourneyId" type="VARCHAR(36)">
                <constraints nullable="true"/>
            </column>
            <column name="utcCreatedAt" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="createdBy" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
