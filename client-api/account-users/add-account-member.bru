meta {
  name: Add Account Member
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/{{accountId}}/members
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "userId": "{{userId}}",
    "role": "MEMBER"
  }
}
